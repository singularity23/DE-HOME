# Adobe Sign Integration - Environment Configuration Template
# 
# Copy this file to .env and fill in your actual values
# DO NOT commit .env to version control (contains secrets)

# ============================================================================
# ADOBE SIGN API CREDENTIALS
# ============================================================================

# OAuth Client ID from Adobe Sign admin console
ADOBE_SIGN_CLIENT_ID=your_client_id_here

# OAuth Client Secret (KEEP SECRET!)
ADOBE_SIGN_CLIENT_SECRET=your_client_secret_here

# OAuth Access Token for API authentication
# Obtain from Adobe Sign via OAuth flow or admin console
ADOBE_SIGN_ACCESS_TOKEN=your_access_token_here

# OAuth Refresh Token (used to auto-refresh access token)
ADOBE_SIGN_REFRESH_TOKEN=your_refresh_token_here

# Webhook secret for validating incoming webhook events
ADOBE_SIGN_WEBHOOK_SECRET=your_webhook_secret_here

# Adobe Sign API base URL
ADOBE_SIGN_BASE_URL=https://api.adobesign.com/api/rest/v6

# Adobe Sign OAuth endpoint
ADOBE_SIGN_OAUTH_URL=https://oauth.adobesign.com/oauth/token

# Redirect URI for OAuth (must match Adobe Sign app settings)
ADOBE_SIGN_REDIRECT_URI=http://localhost:5000/api/oauth/callback

# ============================================================================
# FLASK SERVER CONFIGURATION
# ============================================================================

# Port to run Flask server on
FLASK_PORT=5000

# Enable debug mode (DO NOT enable in production)
FLASK_DEBUG=False

# Flask app name
FLASK_APP=adobe_sign_server.py

# ============================================================================
# UPLOAD CONFIGURATION
# ============================================================================

# Maximum upload file size in MB
MAX_UPLOAD_SIZE_MB=50

# Upload folder for temporary files
UPLOAD_FOLDER=./sites/de/SiteAssets/python/adobe_sign_uploads

# ============================================================================
# SHAREPOINT CONFIGURATION (Optional)
# ============================================================================

# SharePoint site URL
SHAREPOINT_SITE_URL=https://hydroshare.bchydro.bc.ca/sites/de

# SharePoint list name for signed documents
SHAREPOINT_SIGNED_DOCS_LIST=Signed Documents

# ============================================================================
# EMAIL CONFIGURATION (Optional)
# ============================================================================

# SMTP server for sending notifications
EMAIL_SMTP_SERVER=smtp.office365.com

# SMTP port
EMAIL_SMTP_PORT=587

# Email account for notifications
EMAIL_FROM_ADDRESS=noreply@example.com

# Email account password
EMAIL_PASSWORD=your_email_password

# ============================================================================
# LOGGING & DEBUGGING
# ============================================================================

# Log level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# Log file location
LOG_FILE=./logs/adobe_sign.log

# Enable request logging
LOG_REQUESTS=True

# ============================================================================
# SECURITY
# ============================================================================

# Enable HTTPS only (production)
HTTPS_ONLY=False

# CORS allowed origins (comma-separated)
CORS_ORIGINS=http://localhost:5000,http://localhost:3000,https://hydroshare.bchydro.bc.ca

# ============================================================================
# FEATURE FLAGS
# ============================================================================

# Enable webhook receiver
ENABLE_WEBHOOKS=True

# Enable local file caching
ENABLE_CACHING=True

# Auto-refresh expired tokens
AUTO_REFRESH_TOKENS=True

# Store webhook events in local file
STORE_WEBHOOK_EVENTS=True

# ============================================================================
# DEVELOPMENT / TESTING
# ============================================================================

# Use mock Adobe Sign API (for testing without real account)
USE_MOCK_API=False

# Store agreements in local JSON file (for testing)
LOCAL_STORAGE_ENABLED=False

# Test mode (bypasses some validation)
TEST_MODE=False
